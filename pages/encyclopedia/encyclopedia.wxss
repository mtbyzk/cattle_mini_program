/* pages/encyclopedia/encyclopedia.wxss */

.container {
  padding: 24rpx;
  padding-bottom: 120rpx;
}

/* 搜索框 */
.search-bar {
  background-color: #FFFFFF;
  border-radius: 50rpx;
  padding: 16rpx 24rpx;
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.search-bar .search-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.search-bar input {
  flex: 1;
  font-size: 28rpx;
  color: #1A1A1A;
}

.search-bar input::placeholder {
  color: #999999;
}

/* 标签选择器 */
.tag-scroll {
  white-space: nowrap;
  margin-bottom: 24rpx;
}

.tag-selector {
  display: inline-flex;
  gap: 12rpx;
  padding: 4rpx 0;
}

.tag-selector .tag {
  padding: 12rpx 24rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  background-color: #FFFFFF;
  color: #666666;
  border: 2rpx solid #EEEEEE;
  white-space: nowrap;
}

.tag-selector .tag.active {
  background-color: #8B4513;
  color: #FFFFFF;
  border-color: #8B4513;
}

/* 加载状态 */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #EEEEEE;
  border-top-color: #8B4513;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  margin-top: 24rpx;
  font-size: 28rpx;
  color: #999999;
}

/* 疾病列表 */
.disease-list {
  margin-bottom: 24rpx;
}

.disease-item {
  background-color: #FFFFFF;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.disease-item .icon-wrapper {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.disease-item .disease-icon {
  font-size: 40rpx;
}

.disease-item .content {
  flex: 1;
  min-width: 0;
}

.disease-item .content .name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1A1A1A;
}

.disease-item .content .desc {
  font-size: 24rpx;
  color: #666666;
  margin-top: 8rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.disease-item .content .tags {
  display: flex;
  gap: 12rpx;
  margin-top: 12rpx;
}

.disease-item .arrow {
  font-size: 40rpx;
  color: #CCCCCC;
  margin-left: 16rpx;
  flex-shrink: 0;
}

.tag {
  display: inline-block;
  padding: 8rpx 16rpx;
  border-radius: 16rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.tag-primary {
  background-color: rgba(139, 69, 19, 0.1);
  color: #8B4513;
}

.tag-success {
  background-color: rgba(46, 213, 115, 0.1);
  color: #2ED573;
}

.tag-warning {
  background-color: rgba(255, 165, 2, 0.1);
  color: #FFA502;
}

.tag-danger {
  background-color: rgba(255, 71, 87, 0.1);
  color: #FF4757;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 80rpx 0;
}

.empty-state .empty-icon {
  font-size: 60rpx;
  margin-bottom: 16rpx;
}

.empty-state .text {
  font-size: 28rpx;
  color: #999999;
}

.empty-state .sub-text {
  font-size: 24rpx;
  color: #CCCCCC;
}
